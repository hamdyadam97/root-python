# Root monorepo .gitignore

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editors / IDEs
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

# Environment / secrets
.env
.env.local
.env.*.local
*.pem
*.key

# Logs
*.log
logs/

# Docker
*.pid

# Backend (Django)
backend/.venv/
backend/venv/
backend/env/
backend/__pycache__/
backend/**/*.py[cod]
backend/**/*$py.class
backend/*.sqlite3
backend/*.sqlite3-journal
backend/db.sqlite3
backend/db.sqlite3-journal
backend/media/
backend/staticfiles/
backend/.pytest_cache/
backend/.mypy_cache/
backend/htmlcov/
backend/.coverage
backend/.tox/
backend/.nox/
backend/static_src/node_modules/
backend/static_src/dist/

# Frontend (Next.js)
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/.vercel/
frontend/.turbo/
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# Misc
*.tmp
*.temp
.cache/
